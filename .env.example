# ── Supabase ────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. Until these are set, the app runs in DEMO MODE
# (seeded in-memory data + a one-click demo login). With them set, it becomes
# a real backend: real auth, persisted progress, admin invites, video storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only. Used for admin actions (inviting starters,
# bulk import). NEVER expose this to the browser / commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the deployed site (used for invite links / email redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email sending (Resend) ────────────────────────────────────────────────────
# Create a key at https://resend.com (Settings → API Keys). Until set, the
# Email Templates can be designed/previewed but not sent.
RESEND_API_KEY=
# The verified "from" address. For quick testing you can use Resend's sandbox
# sender below (only delivers to your own Resend account email). For production,
# verify your domain in Resend and use e.g. "PossAbilities <noreply@possabilities.org.uk>".
EMAIL_FROM=PossAbilities <onboarding@resend.dev>

# ── Scheduled reminders ───────────────────────────────────────────────────────
# Shared secret protecting the /api/cron/reminders endpoint. Set the SAME value
# here and in Netlify env vars so the daily scheduled function can call it.
CRON_SECRET=
# Days of inactivity before a starter is "stalled" and gets a reminder (default 3).
REMINDER_STALE_DAYS=3
